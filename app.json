{
  "name": "The Slow Turn",
  "description": "Team command center — Safe to port",
  "repo": "https://github.com/MrJoeDiablo/The-Slow-Turn",
  "services": [
    {
      "name": "web",
      "github": {
        "repo": "MrJoeDiablo/The-Slow-Turn",
        "branch": "main",
        "deploy_on_push": true
      },
      "build_command": "npm run install:all && npm run build",
      "run_command": "npm start",
      "environment_slug": "node-js",
      "envs": [
        {
          "key": "NODE_ENV",
          "value": "production",
          "scope": "run_and_build_time",
          "type": "GENERAL"
        },
        {
          "key": "VITE_SUPABASE_URL",
          "value": "https://vqtibmhminomemtsbkgh.supabase.co",
          "scope": "build_time",
          "type": "GENERAL"
        },
        {
          "key": "VITE_SUPABASE_PUBLISHABLE_KEY",
          "value": "sb_publishable_aPtldjkzD38fiSoIWXGpSA_Wr5ofiGL",
          "scope": "build_time",
          "type": "GENERAL"
        },
        {
          "key": "VITE_SUPABASE_PROJECT_ID",
          "value": "vqtibmhminomemtsbkgh",
          "scope": "build_time",
          "type": "GENERAL"
        }
      ],
      "http_port": 5000,
      "health_check": {
        "http_path": "/api/health"
      }
    }
  ],
  "databases": [
    {
      "name": "db",
      "engine": "PG",
      "version": "17"
    }
  ]
}
